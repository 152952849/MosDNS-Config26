
config mosdns 'config'
	option enabled '1'
	option geo_auto_update '1'
	option geo_update_week_time '1'
	option geo_update_day_time '1'
	option configfile '/etc/mosdns/config_custom.yaml'
	list geosite_tags 'gfw'
	list geosite_tags 'geolocation-!cn'
	list geosite_tags 'cn'
	list geoip_tags 'cn'
	list geoip_tags 'private'
	option geoip_type 'geoip-only-cn-private'
	option github_proxy 'https://git.lanx.cf'

